# ─────────────────────────────────────────────
#  AI CLI Agent — Environment Configuration
#  Copy this file to .env and edit as needed:
#    cp .env.example .env
# ─────────────────────────────────────────────

# Ollama API base URL
OLLAMA_URL=http://localhost:11434/api/chat

# Default model to use when none is entered at startup
# Options: llama3, mistral, phi3, gemma, etc.
DEFAULT_MODEL=llama3

# Maximum number of conversation turns kept in memory
# (older messages are trimmed to stay within context limits)
MAX_HISTORY=20

# Shell command allow-list (comma-separated, no spaces)
# Only these commands are permitted via /sh
ALLOWED_SHELL_COMMANDS=ls,pwd,echo,date,whoami,hostname,uname
